# Umami docker service (compose: umami + umami-db)
# UI: http://localhost:7004
# Default login: admin / umami  (change after first login)
# Nest host uses root .env: UMAMI_BASE_URL=http://localhost:7004 + UMAMI_USERNAME/PASSWORD
# Nest in-docker uses: UMAMI_BASE_URL=http://umami:3000

UMAMI_IMAGE=ghcr.io/umami-software/umami:postgresql-latest
UMAMI_DB_NAME=umami
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=umami
UMAMI_APP_SECRET=liora-umami-dev-secret-change-me-32chars
