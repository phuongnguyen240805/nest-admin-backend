# ================== GLOBAL / SYSTEM ==================
NODE_ENV=development

# ================== NETWORK (Docker) ==================
LIORA_NETWORK_DRIVER=bridge

# ================== DATABASE (libs/database) ==================
# DB_TYPE: mysql (legacy) | postgres (Supabase / PostgreSQL)
DB_TYPE=postgres

# --- PostgreSQL / Supabase (khuyến nghị) ---
# DATABASE_URL=postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/liora_db
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=liora_db
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MAX=10
DB_SYNCHRONIZE=false

# --- MySQL (legacy rollback) ---
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=liora_db
MYSQL_PORT_EXTERNAL=3307

# ================== REDIS (libs/nest-core) ==================
REDIS_HOST=redis
REDIS_PORT=6381
REDIS_PASSWORD=
REDIS_PORT_EXTERNAL=6380
REDIS_URL=redis://redis:6381/0

# ================== JWT / AUTH (libs/nest-core) ==================
JWT_SECRET=liora-dev-jwt-secret-change-in-prod
JWT_EXPIRE=86400
REFRESH_TOKEN_SECRET=liora-dev-refresh-secret-change-in-prod
REFRESH_TOKEN_EXPIRE=2592000

# ================== APP SCOPE (multi-app / shared DB) ==================
# APP_CODE: product app for this process (ladipage | nest-admin | future-app)
APP_CODE=ladipage
# APP_SCOPED_AUTH=false → legacy sys_user.organizationId + lazy membership sync (safe default)
# APP_SCOPED_AUTH=true  → workspace resolved only via sys_user_app_membership per APP_CODE
APP_SCOPED_AUTH=false
LEGACY_APP_CODE=ladipage

# Internal communication (inter-service)
INTERNAL_KEY=secret-sync-token

# ================== SUPABASE (libs/supabase) ==================
USE_SUPABASE_AUTH=true
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
# SUPABASE_ANON_KEY=eyJ...your-anon-jwt...
SUPABASE_SECRET_KEY=sb_secret_or_service_role_jwt_here
SUPABASE_ALLOWED_DOMAINS=gmail.com
SUPABASE_BLOCKED_DOMAINS=tempmail.com,mailinator.com,10minutemail.com,yopmail.com,temp-mail.org,guerrillamail.com,sharklasers.com,dispostable.com,getairmail.com,burnercmail.com,temp-mail.io,mailnesia.com,maildrop.cc,tempmailaddress.com,fakeinbox.com,throwawaymail.com
REGISTRATION_LIMIT_IP_COUNT=3
REGISTRATION_LIMIT_IP_WINDOW=600
REGISTRATION_LIMIT_EMAIL_COUNT=2
REGISTRATION_LIMIT_EMAIL_WINDOW=86400
# REGISTRATION_DISABLE_RATE_LIMIT=true
# SUPABASE_DEV_ADMIN_SIGNUP=true

# ================== STRIPE (libs/nest-core billing) ==================
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SIGNING_SECRET_HERE
# STRIPE_API_VERSION=2025-01-27.acacia
STRIPE_PRICE_PRO_MONTHLY=price_REPLACE_PRO_MONTHLY
STRIPE_PRICE_PRO_YEARLY=price_REPLACE_PRO_YEARLY
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_REPLACE_ENTERPRISE_MONTHLY
STRIPE_PRICE_ENTERPRISE_YEARLY=price_REPLACE_ENTERPRISE_YEARLY
# FRONTEND_URL=http://localhost:3001

# ================== PAYOS (libs/nest-core billing) ==================
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_API_URL=https://api-merchant.payos.vn
PLAN_PRO_MONTHLY_VND=299000
PLAN_PRO_YEARLY_VND=2990000
PLAN_ENTERPRISE_MONTHLY_VND=999000
PLAN_ENTERPRISE_YEARLY_VND=9990000

# ================== LIBREFANG (apps/librefang-backend/libs/librefang-client) ==================
LIBREFANG_API_URL=http://localhost:4545
LIBREFANG_API_KEY=

# ================== OPENSEO / AI SEO ==================
OPENSEO_BASE_URL=http://localhost:7003
OPENSEO_MCP_URL=http://localhost:7003/mcp
AI_SEO_DATAFORSEO_DAILY_QUOTA=0
DATAFORSEO_API_KEY=
OPEN_SEO_IMAGE=ghcr.io/every-app/open-seo:latest
OPENSEO_AUTH_MODE=local_noauth

# Umami traffic microservice (AI-SEO adapter)
# Compose: services umami + umami-db → http://localhost:7004 (UI login admin/umami)
# Inside docker network Nest uses http://umami:3000 (set in docker-compose)
UMAMI_ENABLED=false
UMAMI_BASE_URL=http://localhost:7004
UMAMI_PUBLIC_SCRIPT_URL=http://localhost:7004
# Self-host docker: no API keys UI — use login (default admin / umami)
UMAMI_USERNAME=admin
UMAMI_PASSWORD=umami
# Optional static token (login JWT) or Cloud API key — leave empty to use username/password
UMAMI_API_KEY=
UMAMI_IMAGE=ghcr.io/umami-software/umami:postgresql-latest
UMAMI_APP_SECRET=liora-umami-dev-secret-change-me-32chars
UMAMI_DB_NAME=umami
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=umami
UMAMI_TIMEOUT_MS=3000
UMAMI_CIRCUIT_FAILURE_THRESHOLD=5
UMAMI_CIRCUIT_OPEN_MS=60000
UMAMI_CACHE_TTL_SECONDS=300
UMAMI_CACHE_STALE_TTL_SECONDS=3600

# ================== DOCKER COMPOSE ==================
# docker compose override hostname trong network (db, redis, minio)
# Chạy: pnpm docker:up

# MinIO (nếu dùng)
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin

# ==================================================== ENV - LADIPAGE =============================================================
# BullMQ
BULLMQ_ENABLED=true
BULLMQ_PREFIX=liora:ladipage
REDIS_URL=redis://localhost:6381

# Dev không cần s2c — dùng mock
LANDING_AI_MOCK_GENERATE=false

# Production AI thật (host dev: nx serve ladipage-backend)
SCREENSHOT_TO_CODE_HTTP_URL=http://localhost:7010
SCREENSHOT_TO_CODE_WS_URL=ws://localhost:7010
S2C_DEFAULT_STACK=html_css
S2C_GENERATE_TIMEOUT_MS=300000
GEMINI_API_KEY=your_gcp_api_key_here
SCREENSHOTONE_API_KEY=your_gcp_api_key_here
# API (ladipage-backend)
BULLMQ_RUN_WORKERS=true   # dev single-process
# BULLMQ_RUN_WORKERS=false  # production API-only

# dev
LANDING_REVALIDATE_SECRET=...
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PUBLISH_API=v2 
LANDING_CUSTOM_DOMAIN_EDGE_ENABLED=false

# Plan A — free subdomain https://{slug}.{FREE_SITE_DOMAIN}
# Keep false until DNS wildcard + Worker proxy are ready.
LANDING_FREE_SUBDOMAIN_ENABLED=false
FREE_SITE_DOMAIN=
# FREE_SUBDOMAIN_DELIVERY=proxy
# FREE_SUBDOMAIN_DELIVERY=r2

# Plan B — customer domain (Cloudflare for SaaS + Workers KV)
# CUSTOM_DOMAIN_CNAME_TARGET=fallback.liora.app
# CLOUDFLARE_SAAS_FALLBACK_ORIGIN=fallback.liora.app
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_LANDING_ROUTES_KV_ID=
# CLOUDFLARE_LANDING_EDGE_WORKER=liora-landing-edge

# prod
# LANDING_CUSTOM_DOMAIN_EDGE_ENABLED=true
# LANDING_FREE_SUBDOMAIN_ENABLED=true
# FREE_SITE_DOMAIN=liora.app
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_LANDING_ROUTES_KV_ID=...
# LANDING_ORIGIN_BASE_URL=https://app.liora.vn
