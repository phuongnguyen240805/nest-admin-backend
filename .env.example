# ================== GLOBAL / SYSTEM ==================
NODE_ENV=development

# ================== NETWORK ==================
LIORA_NETWORK_DRIVER=bridge

# ================== DATABASE ==================
# DB_TYPE: mysql (legacy) | postgres (Supabase / PostgreSQL)
DB_TYPE=postgres

# --- PostgreSQL / Supabase (khuyến nghị) ---
# DATABASE_URL=postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/liora_db
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=liora_db
DB_USERNAME=postgres
DB_PASSWORD=postgres
# Supabase requires SSL; local docker postgres can use false
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# Supabase direct (migrations): port 5432
# Supabase pooler (runtime): port 6543 + ?pgbouncer=true
DB_POOL_MAX=10

# --- MySQL (legacy rollback) ---
# DB_TYPE=mysql
# DATABASE_URL=mysql://user:password@db-host:3306/liora_db
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=liora_db
MYSQL_PORT_EXTERNAL=3307

# ================== REDIS ==================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                    # để trống nếu không có password

# External port (cho máy host)
REDIS_PORT_EXTERNAL=6380

# REDIS_URL dùng cho các service connect nội bộ
REDIS_URL=redis://redis:6379/0

# ================== DOCKER LOCAL ==================
# Chạy stack: pnpm docker:up  (từ root, dùng file .env này)
# PORT dùng trong container nest-admin (docker-compose set PORT=7001)

# ================== NEST-ADMIN BACKEND ==================
NEST_ADMIN_PORT=7001
PORT=7001

# ================== LADIPAGE BACKEND ==================
LADIPAGE_PORT=7002

# Database config (docker override DB_HOST=db)
DB_SYNCHRONIZE=false

# Redis config
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=liora-dev-jwt-secret-change-in-prod
JWT_EXPIRE=7
REFRESH_TOKEN_SECRET=liora-dev-refresh-secret-change-in-prod
REFRESH_TOKEN_EXPIRE=30

# Internal communication
INTERNAL_KEY=secret-sync-token

# ================== DONUT-SYNC BACKEND ==================
DONUT_SYNC_PORT=3000
SYNC_TOKEN=secret-sync-token


# ================== SUPABASE & ANTI-SPAM AUTH ==================
USE_SUPABASE_AUTH=true
SUPABASE_URL=https://your-supabase-project.supabase.co

# Public keys (safe for client + Nest auth) — pick ONE, publishable preferred:
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
# SUPABASE_ANON_KEY=eyJ...your-anon-jwt...

# Secret key (service_role) — SERVER ONLY, never expose to browser:
SUPABASE_SECRET_KEY=sb_secret_or_service_role_jwt_here

# Deprecated (still supported as fallback):
# SUPABASE_KEY=...
# SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_ALLOWED_DOMAINS=gmail.com
SUPABASE_BLOCKED_DOMAINS=tempmail.com,mailinator.com,10minutemail.com,yopmail.com,temp-mail.org,guerrillamail.com,sharklasers.com,dispostable.com,getairmail.com,burnercmail.com,temp-mail.io,mailnesia.com,maildrop.cc,tempmailaddress.com,fakeinbox.com,throwawaymail.com
REGISTRATION_LIMIT_IP_COUNT=3
REGISTRATION_LIMIT_IP_WINDOW=600
REGISTRATION_LIMIT_EMAIL_COUNT=2
REGISTRATION_LIMIT_EMAIL_WINDOW=86400

# ================== STRIPE (for billing inside nest-core) ==================
# Required for the new Stripe integration colocated in libs/nest-core/src/modules/billing/stripe/
# Get test keys from https://dashboard.stripe.com/test/apikeys
# 1. Put your sk_test_... here
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE

# 2. After running `stripe listen`, it will print a whsec_... secret.
#    Put it here, then restart the admin backend.
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SIGNING_SECRET_HERE

# Optional: pin a specific Stripe API version (recommended for stability)
# STRIPE_API_VERSION=2025-01-27.acacia

# FRONTEND_URL is used by some checkout/portal return URLs in the code
# FRONTEND_URL=http://localhost:3001

# Note on webhook URL:
# The endpoint exposed by BillingModule + StripeWebhookModule is:
#   http://localhost:7001/api/webhooks/stripe
# (because nest-admin uses globalPrefix: "api" and the controller is @Controller('webhooks/stripe'))
#
# To test with real events:
#   - pnpm nx serve nest-admin-backend   (in one terminal, make sure .env is loaded)
#   - stripe login   (first time)
#   - stripe listen --forward-to http://localhost:7001/api/webhooks/stripe
#   - (copy the whsec_... printed by listen into STRIPE_WEBHOOK_SECRET above, restart serve)
#   - stripe trigger checkout.session.completed
#   - stripe trigger invoice.paid
#   - stripe trigger customer.subscription.created
#
# You should see logs from BillingWebhookHandlers in the admin backend console.