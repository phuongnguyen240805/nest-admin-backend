{
  "name": "nest-core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/nest-core/src",
  "projectType": "library",
  "tags": ["scope:core", "type:library"],
  "targets": {
    "build": {
      "executor": "@nx/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/nest-core",
        "main": "libs/nest-core/src/index.ts",
        "tsConfig": "libs/nest-core/tsconfig.lib.json",
        "skipTypeCheck": true,
        "assets": ["libs/nest-core/*.md"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/nest-core"],
      "options": {
        "jestConfig": "libs/nest-core/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "implicitDependencies": ["database", "shared", "dto", "librefang-client", "supabase"]
}
