{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "../..",
    "paths": {
      "~/*": ["src/*"],
      "@liora/database": ["../database/src/index.ts"],
      "@liora/database/*": ["../database/src/*"],
      "@liora/dto": ["../dto/src/index.ts"],
      "@liora/dto/*": ["../dto/src/*"],
      "@liora/shared": ["../shared/src/index.ts"],
      "@liora/shared/*": ["../shared/src/*"],
      "@liora/librefang-client": ["../librefang-client/src/index.ts"],
      "@liora/librefang-client/*": ["../librefang-client/src/*"]
    },
    "module": "commonjs",
    "forceConsistentCasingInFileNames": false,
    "strict": false,
    "importHelpers": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true
  },
  "files": [],
  "include": ["src/**/*.ts", "src/types/**/*.d.ts"],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}
