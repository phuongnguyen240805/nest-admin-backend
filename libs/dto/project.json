{
    "name": "dto",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "libs/dto/src",
    "projectType": "library",
    "targets": {
        "build": {
            "executor": "@nx/js:tsc",
            "outputs": [
                "{options.outputPath}"
            ],
            "options": {
                "outputPath": "dist/libs/dto",
                "tsConfig": "libs/dto/tsconfig.lib.json",
                "main": "libs/dto/src/index.ts",
                "rootDir": "src"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint"
        }
    }
}