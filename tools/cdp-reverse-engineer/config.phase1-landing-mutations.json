{
  "url": "https://appv6.ladipage.com/ladipage",
  "durationMs": 15000,
  "headless": true,
  "outputDir": "output/phase1-landing-mutations",
  "maxBodyBytes": 4194304,
  "storageStatePath": ".session/ladipage-appv6-auth.json",
  "actions": [
    { "type": "wait", "ms": 8000 },
    { "type": "click", "selector": "button:has-text('Tạo Landing Page'), button:has-text('Tạo trang')", "label": "open-create-lp" },
    { "type": "wait", "ms": 5000 },
    { "type": "click", "selector": "button:has-text('Trang trắng'), button:has-text('Tạo trang trắng'), [data-testid*='blank']", "label": "create-blank-lp", "force": true },
    { "type": "wait", "ms": 12000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ladipage", "label": "back-after-create" },
    { "type": "wait", "ms": 6000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ladipage/tags", "label": "tags-mutation" },
    { "type": "wait", "ms": 5000 },
    { "type": "click", "selector": "button[aria-label='Tạo Tag mới'], button:has-text('Tạo Tag')", "label": "open-create-tag" },
    { "type": "wait", "ms": 2000 },
    { "type": "fill", "selector": "input[name='name'], input[placeholder*='tag'], input[placeholder*='Tag'], input[type='text']", "value": "cdp-test-tag", "label": "fill-tag-name" },
    { "type": "wait", "ms": 1000 },
    { "type": "click", "selector": "button:has-text('Lưu'), button:has-text('Tạo'), button:has-text('Xác nhận')", "label": "submit-tag", "force": true },
    { "type": "wait", "ms": 8000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ladipage/forms", "label": "forms-mutation" },
    { "type": "wait", "ms": 5000 },
    { "type": "click", "selector": "button:has-text('Tạo cấu hình Form'), button:has-text('Tạo Form')", "label": "open-create-form" },
    { "type": "wait", "ms": 3000 },
    { "type": "fill", "selector": "input[name='name'], input[placeholder*='tên'], input[type='text']", "value": "cdp-test-form", "label": "fill-form-name" },
    { "type": "click", "selector": "button:has-text('Lưu'), button:has-text('Tạo'), button:has-text('Tiếp tục')", "label": "submit-form", "force": true },
    { "type": "wait", "ms": 8000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ladipage", "label": "duplicate-flow" },
    { "type": "wait", "ms": 6000 },
    { "type": "click", "selector": "table tbody tr:first-child button:last-child", "label": "row-menu-dup" },
    { "type": "wait", "ms": 1500 },
    { "type": "click", "selector": "[role='menuitem']:has-text('Nhân bản')", "label": "duplicate-page" },
    { "type": "wait", "ms": 2000 },
    { "type": "click", "selector": "button:has-text('Xác nhận'), button:has-text('Nhân bản'), button:has-text('Đồng ý')", "label": "confirm-duplicate", "force": true },
    { "type": "wait", "ms": 12000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/editor/6a37eb9931cd7400125f766f", "label": "editor-save" },
    { "type": "wait", "ms": 25000 },
    { "type": "click", "selector": "button:has-text('Lưu'), button:has-text('Save'), [aria-label*='Lưu']", "label": "save-editor", "force": true },
    { "type": "wait", "ms": 10000 }
  ]
}