{
  "url": "https://appv6.ladipage.com/ecommerce/orders",
  "durationMs": 12000,
  "headless": true,
  "outputDir": "output/phase2-banhang-mutations",
  "maxBodyBytes": 4194304,
  "storageStatePath": ".session/ladipage-appv6-auth.json",
  "actions": [
    { "type": "wait", "ms": 8000 },
    { "type": "click", "selector": "button:has-text('Tạo đơn hàng')", "label": "open-create-order" },
    { "type": "wait", "ms": 5000 },
    { "type": "fill", "selector": "input[name*='phone'], input[placeholder*='điện thoại'], input[placeholder*='SĐT']", "value": "0901234567", "label": "order-phone" },
    { "type": "fill", "selector": "input[name*='name'], input[placeholder*='tên'], input[placeholder*='Tên']", "value": "CDP Test Customer", "label": "order-name" },
    { "type": "fill", "selector": "input[name*='email'], input[placeholder*='email']", "value": "cdp-test@example.com", "label": "order-email" },
    { "type": "click", "selector": "button:has-text('Lưu'), button:has-text('Tạo đơn'), button:has-text('Xác nhận')", "label": "submit-order", "force": true },
    { "type": "wait", "ms": 10000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/orders", "label": "orders-after-create" },
    { "type": "wait", "ms": 6000 },
    { "type": "click", "selector": "table tbody tr:first-child", "label": "order-detail", "force": true },
    { "type": "wait", "ms": 12000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/orders/tags", "label": "create-order-tag" },
    { "type": "wait", "ms": 5000 },
    { "type": "click", "selector": "button:has-text('Tạo'), button[aria-label*='Tạo']", "label": "open-order-tag-modal", "force": true },
    { "type": "wait", "ms": 2000 },
    { "type": "fill", "selector": "input[type='text'], input[name='name']", "value": "cdp-order-tag", "label": "fill-order-tag" },
    { "type": "click", "selector": "button:has-text('Lưu'), button:has-text('Tạo')", "label": "submit-order-tag", "force": true },
    { "type": "wait", "ms": 8000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/products", "label": "create-product" },
    { "type": "wait", "ms": 6000 },
    { "type": "click", "selector": "button:has-text('Tạo sản phẩm'), button:has-text('Thêm sản phẩm'), button:has-text('Tạo')", "label": "open-create-product" },
    { "type": "wait", "ms": 4000 },
    { "type": "fill", "selector": "input[name*='name'], input[placeholder*='tên sản phẩm'], input[placeholder*='Tên']", "value": "CDP Test Product", "label": "product-name" },
    { "type": "fill", "selector": "input[name*='price'], input[placeholder*='giá'], input[type='number']", "value": "199000", "label": "product-price" },
    { "type": "click", "selector": "button:has-text('Lưu'), button:has-text('Tạo'), button:has-text('Xuất bản')", "label": "submit-product", "force": true },
    { "type": "wait", "ms": 10000 },
    { "type": "click", "selector": "table tbody tr:first-child", "label": "product-detail", "force": true },
    { "type": "wait", "ms": 12000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/products/categories", "label": "create-category" },
    { "type": "wait", "ms": 5000 },
    { "type": "click", "selector": "button:has-text('Tạo'), button:has-text('Thêm')", "label": "open-category", "force": true },
    { "type": "wait", "ms": 2000 },
    { "type": "fill", "selector": "input[type='text']", "value": "CDP Category", "label": "category-name" },
    { "type": "click", "selector": "button:has-text('Lưu'), button:has-text('Tạo')", "label": "submit-category", "force": true },
    { "type": "wait", "ms": 8000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/orders", "label": "export-sync" },
    { "type": "wait", "ms": 5000 },
    { "type": "click", "selector": "button:has-text('Thao tác')", "label": "actions-menu" },
    { "type": "wait", "ms": 2000 },
    { "type": "click", "selector": "button:has-text('Xuất/Đồng bộ dữ liệu'), [role='menuitem']:has-text('Xuất')", "label": "export-data", "force": true },
    { "type": "wait", "ms": 8000 }
  ]
}