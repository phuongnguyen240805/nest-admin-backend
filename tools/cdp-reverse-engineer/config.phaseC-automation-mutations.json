{
  "url": "https://appv6.ladipage.com/automation/flows",
  "durationMs": 12000,
  "headless": true,
  "outputDir": "output/phaseC-automation-mutations",
  "maxBodyBytes": 4194304,
  "storageStatePath": ".session/ladipage-appv6-auth.json",
  "actions": [
    { "type": "wait", "ms": 10000, "label": "flows-list" },
    { "type": "click", "selector": "button:has-text('Tạo Flow'), button:has-text('Tạo mới'), button:has-text('Tạo'), a:has-text('Tạo Flow'), [class*='create-flow']", "label": "create-flow", "force": true },
    { "type": "wait", "ms": 5000 },
    { "type": "fill", "selector": "input[name*='name'], input[placeholder*='tên'], input[placeholder*='Tên'], input[type='text']:visible", "value": "CDP Automation Flow", "label": "flow-name" },
    { "type": "click", "selector": "button:has-text('Lưu'), button:has-text('Tạo'), button:has-text('Tiếp tục'), button:has-text('Xác nhận')", "label": "save-flow", "force": true },
    { "type": "wait", "ms": 12000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/automation/broadcasts", "label": "goto-broadcasts" },
    { "type": "wait", "ms": 8000 },
    { "type": "click", "selector": "button:has-text('Tạo Broadcast'), button:has-text('Tạo mới'), button:has-text('Tạo')", "label": "create-broadcast", "force": true },
    { "type": "wait", "ms": 5000 },
    { "type": "fill", "selector": "input[type='text']:visible", "value": "CDP Broadcast Test", "label": "broadcast-name" },
    { "type": "click", "selector": "button:has-text('Lưu'), button:has-text('Tạo')", "label": "save-broadcast", "force": true },
    { "type": "wait", "ms": 10000 }
  ]
}