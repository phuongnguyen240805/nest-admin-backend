{
  "url": "https://appv6.ladipage.com/apps",
  "durationMs": 10000,
  "headless": true,
  "outputDir": "output/phaseA-kho-ung-dung-mutations",
  "maxBodyBytes": 4194304,
  "storageStatePath": ".session/ladipage-appv6-auth.json",
  "actions": [
    { "type": "wait", "ms": 10000, "label": "app-list" },
    { "type": "click", "selector": "text=Automation, [data-app-code='Automation']", "label": "select-automation", "force": true },
    { "type": "wait", "ms": 5000 },
    { "type": "click", "selector": "button:has-text('Kích hoạt'), button:has-text('Activate'), button:has-text('Cài đặt'), button:has-text('Dùng thử')", "label": "activate-automation", "force": true },
    { "type": "wait", "ms": 8000 },
    { "type": "click", "selector": "button:has-text('Xác nhận'), button:has-text('Đồng ý'), button:has-text('Lưu')", "label": "confirm-activate", "force": true },
    { "type": "wait", "ms": 10000 },
    { "type": "click", "selector": "button:has-text('Ghim'), button:has-text('Pin'), [aria-label*='pin'], [aria-label*='Ghim']", "label": "pin-app", "force": true },
    { "type": "wait", "ms": 8000 },
    { "type": "click", "selector": "text=LadiWork, [data-app-code='LadiWork']", "label": "select-ladiwork", "force": true },
    { "type": "wait", "ms": 5000 },
    { "type": "click", "selector": "button:has-text('Mở'), button:has-text('Open'), button:has-text('Truy cập')", "label": "open-ladiwork", "force": true },
    { "type": "wait", "ms": 10000 }
  ]
}