  "actions": [
    { "type": "wait", "ms": 8000, "label": "orders-list" },
    { "type": "click", "selector": "button:has-text('Lọc nâng cao')", "label": "advanced-filter" },
    { "type": "wait", "ms": 4000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/orders/incomplete", "label": "incomplete" },
    { "type": "wait", "ms": 8000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/orders/shipments", "label": "shipments" },
    { "type": "wait", "ms": 8000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/orders/tags", "label": "order-tags" },
    { "type": "wait", "ms": 6000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/orders/custom-fields", "label": "order-custom-fields" },
    { "type": "wait", "ms": 6000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/products", "label": "products" },
    { "type": "wait", "ms": 8000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/products/categories", "label": "categories" },
    { "type": "wait", "ms": 6000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/products/tags", "label": "product-tags" },
    { "type": "wait", "ms": 6000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/products/inventory", "label": "inventory" },
    { "type": "wait", "ms": 6000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/products/reviews", "label": "reviews" },
    { "type": "wait", "ms": 6000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/products/fields", "label": "product-fields" },
    { "type": "wait", "ms": 6000 },
    { "type": "click", "selector": "table tbody tr:first-child", "label": "open-first-order", "force": true },
    { "type": "wait", "ms": 10000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/products", "label": "back-products" },
    { "type": "wait", "ms": 6000 },
    { "type": "click", "selector": "table tbody tr:first-child", "label": "open-first-product", "force": true },
    { "type": "wait", "ms": 10000 }
  ]
