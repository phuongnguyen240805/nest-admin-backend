{
  "url": "https://appv6.ladipage.com/ladiwork/board/6a3a8d71da6cd800128221ee",
  "durationMs": 15000,
  "headless": true,
  "outputDir": "output/phaseB-ladiwork-board",
  "maxBodyBytes": 4194304,
  "storageStatePath": ".session/ladipage-appv6-auth.json",
  "actions": [
    { "type": "wait", "ms": 12000, "label": "board-load" },
    { "type": "waitForSelector", "selector": "[class*='deal'], [class*='card'], [class*='kanban'], [class*='pipeline'], main", "ms": 25000, "label": "board-ready" },
    { "type": "click", "selector": "[class*='deal-card']:first-child, [class*='DealCard']:first-child, [class*='card']:has-text('CDP'), [class*='card']:first-child", "label": "open-deal-card", "force": true },
    { "type": "wait", "ms": 12000 },
    { "type": "click", "selector": "[role='tab']:has-text('Chi tiết'), [role='tab']:has-text('Thông tin'), button:has-text('Chi tiết')", "label": "tab-detail", "force": true },
    { "type": "wait", "ms": 8000 },
    { "type": "click", "selector": "[role='tab']:has-text('Hoạt động'), [role='tab']:has-text('Bình luận'), button:has-text('Hoạt động')", "label": "tab-activity", "force": true },
    { "type": "wait", "ms": 10000 },
    { "type": "click", "selector": "[role='tab']:has-text('Tệp'), [role='tab']:has-text('File'), button:has-text('Tệp đính kèm')", "label": "tab-files", "force": true },
    { "type": "wait", "ms": 8000 }
  ]
}