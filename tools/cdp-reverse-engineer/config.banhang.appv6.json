{
  "url": "https://appv6.ladipage.com/ecommerce/orders",
  "durationMs": 20000,
  "headless": true,
  "outputDir": "output/banhang-appv6-full",
  "maxBodyBytes": 2097152,
  "storageStatePath": ".session/ladipage-appv6-auth.json",
  "actions": [
    { "type": "wait", "ms": 8000 },
    { "type": "click", "selector": "button:has-text('Tạo đơn hàng')" },
    { "type": "wait", "ms": 5000 },
    { "type": "click", "selector": "button:has-text('Lọc nâng cao')" },
    { "type": "wait", "ms": 3000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/orders/incomplete" },
    { "type": "wait", "ms": 7000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/orders/shipments" },
    { "type": "wait", "ms": 7000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/orders/tags" },
    { "type": "wait", "ms": 6000 },
    { "type": "click", "selector": "button:has-text('Tạo'), button[aria-label*='Tạo']" },
    { "type": "wait", "ms": 4000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/orders/custom-fields" },
    { "type": "wait", "ms": 6000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/products" },
    { "type": "wait", "ms": 7000 },
    { "type": "click", "selector": "button:has-text('Tạo sản phẩm'), button:has-text('Thêm sản phẩm'), button:has-text('Tạo')" },
    { "type": "wait", "ms": 5000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/products/categories" },
    { "type": "wait", "ms": 6000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/products/tags" },
    { "type": "wait", "ms": 6000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/products/inventory" },
    { "type": "wait", "ms": 6000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/products/reviews" },
    { "type": "wait", "ms": 6000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/products/fields" },
    { "type": "wait", "ms": 6000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/orders" },
    { "type": "wait", "ms": 6000 },
    { "type": "click", "selector": "button:has-text('Thao tác')" },
    { "type": "wait", "ms": 3000 },
    { "type": "click", "selector": "button:has-text('Xuất/Đồng bộ dữ liệu')" },
    { "type": "wait", "ms": 5000 }
  ]
}