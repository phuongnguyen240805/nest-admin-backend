{
  "url": "https://appv6.ladipage.com/reports",
  "durationMs": 15000,
  "headless": true,
  "outputDir": "output/phase4-baocao-read",
  "maxBodyBytes": 4194304,
  "storageStatePath": ".session/ladipage-appv6-auth.json",
  "actions": [
    { "type": "wait", "ms": 12000, "label": "reports-load" },
    { "type": "click", "selector": "button:has-text('7 ngày'), button:has-text('30 ngày'), [data-testid*='date-range']", "label": "date-range-7", "force": true },
    { "type": "wait", "ms": 8000 },
    { "type": "click", "selector": "button:has-text('30 ngày'), button:has-text('90 ngày')", "label": "date-range-30", "force": true },
    { "type": "wait", "ms": 8000 },
    { "type": "click", "selector": "[role='tab']:has-text('Doanh thu'), button:has-text('Doanh thu')", "label": "tab-revenue", "force": true },
    { "type": "wait", "ms": 8000 },
    { "type": "click", "selector": "[role='tab']:has-text('Đơn hàng'), button:has-text('Đơn hàng')", "label": "tab-orders", "force": true },
    { "type": "wait", "ms": 8000 },
    { "type": "click", "selector": "[role='tab']:has-text('Khách hàng'), button:has-text('Khách hàng')", "label": "tab-customers", "force": true },
    { "type": "wait", "ms": 8000 },
    { "type": "click", "selector": "[role='tab']:has-text('Sản phẩm'), button:has-text('Sản phẩm')", "label": "tab-products", "force": true },
    { "type": "wait", "ms": 8000 },
    { "type": "click", "selector": "[role='tab']:has-text('Conversion'), button:has-text('Chuyển đổi')", "label": "tab-conversion", "force": true },
    { "type": "wait", "ms": 8000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/dashboard", "label": "dashboard" },
    { "type": "wait", "ms": 12000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/ecommerce/orders", "label": "ecom-reports" },
    { "type": "wait", "ms": 8000 }
  ]
}