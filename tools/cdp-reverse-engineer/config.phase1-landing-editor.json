    { "type": "click", "selector": "button:has-text('Lưu'), button:has-text('Save'), [aria-label*='Lưu']", "label": "save-editor", "force": true },
    { "type": "wait", "ms": 12000 },
    { "type": "click", "selector": "button:has-text('Xuất bản'), button:has-text('Publish')", "label": "open-publish", "force": true },
    { "type": "wait", "ms": 5000 },
    { "type": "click", "selector": "button:has-text('Xuất bản'), button:has-text('Publish'), button:has-text('Xác nhận')", "label": "confirm-publish", "force": true },
    { "type": "wait", "ms": 15000 }
  ]
