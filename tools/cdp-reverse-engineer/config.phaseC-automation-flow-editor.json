{
  "url": "https://appv6.ladipage.com/automation/flows",
  "durationMs": 15000,
  "headless": true,
  "outputDir": "output/phaseC-automation-flow-editor",
  "maxBodyBytes": 4194304,
  "storageStatePath": ".session/ladipage-appv6-auth.json",
  "actions": [
    { "type": "wait", "ms": 10000, "label": "flows-list" },
    { "type": "navigate", "value": "https://appv6.ladipage.com/automation/flows/6a3a8bd0da6cd8001281cbd2/edit", "label": "flow-editor-deep-link" },
    { "type": "wait", "ms": 18000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/automation/flow/6a3a8bd0da6cd8001281cbd2", "label": "flow-editor-v1" },
    { "type": "wait", "ms": 12000 },
    { "type": "click", "selector": "table tbody tr:first-child a, [class*='flow']:first-child a, [class*='flow-card']:first-child", "label": "open-flow-from-list", "force": true },
    { "type": "wait", "ms": 15000 },
    { "type": "click", "selector": "[class*='node']:first-child, [class*='trigger']:first-child, button:has-text('Trigger')", "label": "select-node", "force": true },
    { "type": "wait", "ms": 8000 },
    { "type": "navigate", "value": "https://appv6.ladipage.com/automation/broadcasts", "label": "broadcasts-list" },
    { "type": "wait", "ms": 10000 },
    { "type": "click", "selector": "table tbody tr:first-child, [class*='broadcast']:first-child", "label": "open-broadcast", "force": true },
    { "type": "wait", "ms": 10000 }
  ]
}