# Ports used when Instatic runs beside Ladipage (avoid 3000/3001/5173 clashes).
#
#   CMS (Bun API)  → host 8787
#   Vite admin UI  → host 5174
#
# Nest:  INSTATIC_BASE_URL=http://127.0.0.1:8787
# FE:    INSTATIC_REWRITE_TARGET=http://127.0.0.1:5174

PORT=8787
VITE_PORT=5174

# Optional
# DATABASE_URL=sqlite:./.tmp/dev.db
