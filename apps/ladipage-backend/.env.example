# LadiPage Backend — biến riêng app (nx serve)
# Biến shared libs (DB, JWT, Supabase, Stripe, LibreFang, …) → xem /.env ở root monorepo

PORT=7002
APP_CODE=ladipage
APP_SCOPED_AUTH=false

# Feature flag CRM V2 (chỉ ladipage-backend)
CRM_ENABLED=false

# AI SEO → OpenSEO microservice
OPENSEO_BASE_URL=http://localhost:7003
OPENSEO_MCP_URL=http://localhost:7003/mcp
AI_SEO_DATAFORSEO_DAILY_QUOTA=0

# AI SEO → Umami microservice (traffic adapter; default off)
UMAMI_ENABLED=true
UMAMI_BASE_URL=http://localhost:3002
UMAMI_PUBLIC_SCRIPT_URL=http://localhost:3002
UMAMI_API_KEY=<API key tạo trong Umami admin>
UMAMI_TIMEOUT_MS=3000
UMAMI_CIRCUIT_FAILURE_THRESHOLD=5
UMAMI_CIRCUIT_OPEN_MS=60000
UMAMI_CACHE_TTL_SECONDS=300
UMAMI_CACHE_STALE_TTL_SECONDS=3600


# BullMQ
BULLMQ_ENABLED=true
BULLMQ_PREFIX=liora:ladipage
REDIS_URL=redis://localhost:6381
# Runtime mode (same app, different process):
#   nx serve ladipage-backend        → API (+ worker if true)
#   nx serve-worker ladipage-backend → worker only (worker.main.ts)
# Docker: API container false, worker container true
BULLMQ_RUN_WORKERS=true

# Số lần tạo AI (ai | clone | ppc) mỗi tài khoản Nest — 0 = unlimited (dev)
LANDING_AI_JOBS_PER_USER=5

# Dev không cần s2c — dùng mock
LANDING_AI_MOCK_GENERATE=true

# Production AI thật (host dev: nx serve ladipage-backend)
SCREENSHOT_TO_CODE_HTTP_URL=http://localhost:7010
SCREENSHOT_TO_CODE_WS_URL=ws://localhost:7010
S2C_DEFAULT_STACK=html_css
S2C_GENERATE_TIMEOUT_MS=300000
GEMINI_API_KEY=...
SCREENSHOTONE_API_KEY=...   # cho clone URL

# Docker API container: BULLMQ_RUN_WORKERS=false + nx serve-worker in worker container
# Local single-process dev: BULLMQ_RUN_WORKERS=true