# LadiPage Backend — biến riêng app (nx serve)
# Biến shared libs (DB, JWT, Supabase, Stripe, LibreFang, …) → xem /.env ở root monorepo

PORT=7002

# Feature flag CRM V2 (chỉ ladipage-backend)
CRM_ENABLED=false

# AI SEO → OpenSEO microservice
OPENSEO_BASE_URL=http://localhost:7003
OPENSEO_MCP_URL=http://localhost:7003/mcp
AI_SEO_DATAFORSEO_DAILY_QUOTA=0
