{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2017",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "declaration": false,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "importHelpers": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src/**/*"
  ]
}