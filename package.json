{
  "name": "liora-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "nx run-many --target=build --all",
    "build:libs": "nx run-many --target=build --projects=database,shared,dto,nest-core,crm-core",
    "build:core": "nx run nest-core:build",
    "build:apps": "nx run-many --target=build --projects=goodshort-backend,openclaw-backend,centrix-backend",
    "build:goodshort": "nx run goodshort-backend:build",
    "build:openclaw": "nx run openclaw-backend:build",
    "build:centrix": "nx run centrix-backend:build",
    "build:all": "nx run-many --target=build --all",
    "reset": "nx reset",
    "clean": "rm -rf dist .nx/cache tmp",
    "dev:goodshort": "nx serve goodshort-backend",
    "dev:openclaw": "nx serve openclaw-backend",
    "dev:centrix": "nx serve centrix-backend",
    "dev:ladipage": "nx serve ladipage-backend",
    "build:ladipage": "nx run ladipage-backend:build",
    "start:ladipage:local": "node --env-file=.env dist/apps/ladipage-backend/main.js",
    "graph": "pnpm nx graph",
    "docker:config": "docker compose -f docker/docker-compose.yml --env-file .env config",
    "docker:up": "docker compose -f docker/docker-compose.yml --env-file .env up -d --build",
    "docker:down": "docker compose -f docker/docker-compose.yml --env-file .env down",
    "docker:logs": "docker compose -f docker/docker-compose.yml --env-file .env logs -f",
    "docker:ps": "docker compose -f docker/docker-compose.yml --env-file .env ps",
    "docker:db:migrate": "docker compose -f docker/docker-compose.yml --env-file .env exec -T liora-ladipage pnpm db:migration:run",
    "docker:db:migration:show": "docker compose -f docker/docker-compose.yml --env-file .env exec -T liora-ladipage pnpm db:migration:show",
    "docker:db:repair": "docker compose -f docker/docker-compose.yml --env-file .env exec -T liora-ladipage pnpm db:repair",
    "test:migration": "jest --config=jest.migration.config.ts --runInBand",
    "db:migration:run": "node scripts/db/run-migrations.js",
    "db:migration:show": "node ./node_modules/typeorm/cli-ts-node-commonjs.js migration:show -d libs/database/src/data-source.ts",
    "db:migration:revert": "node ./node_modules/typeorm/cli-ts-node-commonjs.js migration:revert -d libs/database/src/data-source.ts",
    "db:migration:generate": "node ./node_modules/typeorm/cli-ts-node-commonjs.js migration:generate libs/database/src/migrations/$npm_config_name -d libs/database/src/data-source.ts",
    "db:validate": "node scripts/db/validate-schema.js",
    "db:state": "node scripts/db/check-db-state.js",
    "db:repair": "node scripts/db/repair-migration-state.js",
    "db:seed:convert": "node scripts/db/convert-mysql-seed-to-pg.js",
    "db:seed:validate": "node scripts/db/validate-seed.js",
    "db:smoke": "node scripts/db/smoke-test.js",
    "db:smoke:api": "node scripts/db/smoke-test.js --api",
    "db:api:test": "node scripts/db/api-smoke-test.js",
    "db:backfill-orgs": "node scripts/db/backfill-user-organizations.js",
    "db:migrate-crm": "node scripts/db/migrate-lp-crm-to-crm.js",
    "migration:audit:pg": "node scripts/migration/audit-pg.js",
    "migration:audit:mysql": "node scripts/migration/audit-mysql.js",
    "migration:validate": "node scripts/migration/validate-cutover.js",
    "migration:backfill": "node scripts/migration/backfill-supabase-users.js --dry-run",
    "migration:backfill:apply": "node scripts/migration/backfill-supabase-users.js --apply",
    "migration:phase7": "node scripts/migration/run-phase7.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/eslint": "22.7.1",
    "@nx/eslint-plugin": "22.7.1",
    "@nx/jest": "22.7.0",
    "@nx/js": "22.7.1",
    "@nx/nest": "22.7.1",
    "@nx/node": "22.7.1",
    "@nx/web": "22.7.1",
    "@nx/webpack": "22.7.1",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/node": "20.19.9",
    "@types/passport-jwt": "^4.0.1",
    "@types/qs": "^6.15.0",
    "@types/ua-parser-js": "^0.7.39",
    "depcheck": "^1.4.7",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "22.7.0",
    "prettier": "~3.6.2",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "turbo": "^2.9.6",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@liora/api-types": "workspace:*",
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@liaoliaots/nestjs-redis": "^10.0.0",
    "@nestjs-modules/mailer": "^2.3.4",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/bullmq": "^11.0.2",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.19",
    "@socket.io/redis-adapter": "^8.3.0",
    "@socket.io/redis-emitter": "^5.1.0",
    "@supabase/supabase-js": "^2.55.0",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.5",
    "bullmq": "^5.34.0",
    "cache-manager": "^7.2.8",
    "cache-manager-ioredis-yet": "^2.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cron-parser": "^5.5.0",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "evp_bytestokey": "^1.0.3",
    "express": "^5.2.1",
    "fastify": "^5.8.5",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.18.1",
    "mysql2": "^3.22.4",
    "nanoid": "^3.3.7",
    "nestjs-cls": "^6.2.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.20.0",
    "pluralize": "^8.0.0",
    "qiniu": "^7.15.2",
    "qs": "^6.15.1",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "stripe": "^22.1.0",
    "svg-captcha": "^1.4.0",
    "systeminformation": "^5.31.6",
    "typeorm": "^0.3.28",
    "ua-parser-js": "^2.0.9",
    "ws": "^8.18.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  }
}